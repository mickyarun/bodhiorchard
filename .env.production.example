# Production environment — copy to .env.production and fill in every value.
# .env.production is gitignored and must never be committed.

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=bodhiorchard
POSTGRES_PASSWORD=CHANGE_ME        # generate: openssl rand -hex 20
POSTGRES_DB=bodhiorchard

# ── Auth secrets ──────────────────────────────────────────────────────────────
# Generate SECRET_KEY:     python3 -c "import secrets; print(secrets.token_hex(32))"
# Generate ENCRYPTION_KEY: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=GENERATE_ME
ENCRYPTION_KEY=GENERATE_ME

# ── Colyseus bridge ───────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
COLYSEUS_BRIDGE_SECRET=GENERATE_ME

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LLM models ────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
LLM_PREMIUM_MODEL=claude-sonnet-4-6

# ── Public URLs (must match DOMAIN above) ────────────────────────────────────
PUBLIC_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── Integrations (optional) ───────────────────────────────────────────────────
GITHUB_PAT=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── File storage (QA evidence uploads) ────────────────────────────────────────
# Production: S3 is strongly recommended. The default local-disk backend
# survives container rebuilds via the ``evidence_data`` named volume in
# the compose file, but doesn't survive a host loss or scale to >1 backend.
# FILE_STORAGE_S3=true
# FILE_STORAGE_S3_BUCKET=bodhiorchard-evidence-prod
# AWS_REGION=us-east-1
#
# AWS credentials chain (boto3 resolves in order):
#   1. ``AWS_ACCESS_KEY_ID`` + ``AWS_SECRET_ACCESS_KEY`` below.
#   2. ``~/.aws/credentials`` (mount the file into the container).
#   3. EC2 / ECS / EKS instance / task role.
# Prefer instance/task-role IAM. Fall back to static keys only when no
# role is available — the deploy should rotate them regularly.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=    # set only when using temporary STS credentials
