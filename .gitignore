# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.pyc

# Virtual environments
.venv/
venv/
env/

# Environment files
.env
*.env.local
.env.production

# Node / Frontend
node_modules/
frontend/dist/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/

# Docker
*.log

# Backend log capture (rotating handler in app/core/logging.py writes here;
# also covers any one-off `tee` output like logs.txt that may contain JWTs).
backend/logs/
logs.txt

# Database
*.sqlite3
*.db
.gitnexus

# Colyseus dev mode state (may contain JWTs)
.devmode.json

# reposcanv2 sandbox runs (JSON-on-disk persistence)
backend/reposcanv2_runs/

# Hybrid-host data dir (cloned repos + SSH deploy keypair). Default location
# when BODHIORCHARD_DATA_DIR is unset and /data isn't writable. Lives at the
# repo root (not under ``backend/``) so writes don't sit inside uvicorn's CWD
# and trigger reload-watcher cascades during scans. Non-dot name so graphify's
# collect_files walker doesn't drop every indexed file.
repoclone/

# Graphify analyzer output dropped under example repos during scans —
# build artifact, not source.
examples/*/graphify-out/

# Plan and experiment artefacts. These tend to accumulate snapshots of
# real-world tuning data (customer repo names, dataset measurements) that
# don't belong in source control. Keep them local-only.
docs/
backend/experiments/
