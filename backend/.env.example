# Database
DATABASE_URL=postgresql+asyncpg://flowdev:flowdev@localhost:5432/bodhigrove

# Auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=llama3:8b
LLM_BASE_URL=http://localhost:11434
LLM_PREMIUM_PROVIDER=ollama
LLM_PREMIUM_MODEL=llama3:70b

# Embeddings (fastembed runs locally, no external service needed)
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Integrations
GITHUB_PAT=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# WebSocket (real-time push)
WS_HEARTBEAT_INTERVAL=30
WS_MAX_SEND_QUEUE=128
WS_MAX_SUBSCRIBE_QUEUE=32

# Public URL (optional): set when using Cloudflare Tunnel or any reverse proxy
# PUBLIC_URL=https://api.flowdev.yourdomain.com

# Cloudflare Tunnel (optional): only needed with docker compose --profile tunnel
# CLOUDFLARE_TUNNEL_TOKEN=
