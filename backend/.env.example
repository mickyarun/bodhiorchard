# Database
DATABASE_URL=postgresql+asyncpg://bodhiorchard:bodhiorchard@localhost:5432/bodhiorchard

# Auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=llama3:8b
LLM_BASE_URL=http://localhost:11434
LLM_PREMIUM_PROVIDER=ollama
LLM_PREMIUM_MODEL=llama3:70b

# Embeddings (fastembed runs locally, no external service needed)
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Integrations
GITHUB_PAT=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# WebSocket (real-time push)
WS_HEARTBEAT_INTERVAL=30
WS_MAX_SEND_QUEUE=128
WS_MAX_SUBSCRIBE_QUEUE=32

# Storage (optional): root for cloned repos and SSH deploy keys.
# Default: /data when /data is writable (Docker volume mount); otherwise
# <backend>/.data so Hybrid host mode works without manual setup.
# BODHIORCHARD_DATA_DIR=/data

# File storage backend for QA evidence uploads.
# Default is local disk under ``FILE_STORAGE_LOCAL_DIR``. For
# multi-host or production deploys, prefer S3.
# FILE_STORAGE_S3=false
# FILE_STORAGE_S3_BUCKET=
# AWS_REGION=us-east-1
# FILE_STORAGE_LOCAL_DIR=data/uploads
#
# AWS credentials. ``FileStorage`` reads these via pydantic-settings,
# so values declared HERE in ``.env`` are honoured even though boto3's
# OWN default chain reads ``os.environ`` directly (and
# pydantic-settings does NOT populate ``os.environ``). Resolution
# order, highest priority first:
#   1. ``AWS_ACCESS_KEY_ID`` + ``AWS_SECRET_ACCESS_KEY`` below. When
#      BOTH are set, ``FileStorage`` passes them to
#      ``aioboto3.Session(...)`` explicitly, overriding everything
#      below. One without the other is treated as "not set" (almost
#      always a typo) and falls back to the default chain.
#   2. ``~/.aws/credentials`` profile (mounted into the container).
#   3. EC2 / ECS / EKS instance / task role.
# Prefer IAM roles in production — static keys are a credential-leak
# vector that rotates as often as the deploy.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=    # only if using temporary STS credentials

# Public URL (optional): set when using Cloudflare Tunnel or any reverse proxy
# PUBLIC_URL=https://api.bodhiorchard.yourdomain.com

# Cloudflare Tunnel (optional): only needed with docker compose --profile tunnel
# CLOUDFLARE_TUNNEL_TOKEN=
