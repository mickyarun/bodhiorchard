# Database
DATABASE_URL=postgresql+asyncpg://bodhiorchard:bodhiorchard@localhost:5432/bodhiorchard

# Auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=llama3:8b
LLM_BASE_URL=http://localhost:11434
LLM_PREMIUM_PROVIDER=ollama
LLM_PREMIUM_MODEL=llama3:70b

# Embeddings (fastembed runs locally, no external service needed)
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Integrations
GITHUB_PAT=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# WebSocket (real-time push)
WS_HEARTBEAT_INTERVAL=30
WS_MAX_SEND_QUEUE=128
WS_MAX_SUBSCRIBE_QUEUE=32

# Storage (optional): root for cloned repos and SSH deploy keys.
# Default: /data when /data is writable (Docker volume mount); otherwise
# <backend>/.data so Hybrid host mode works without manual setup.
# BODHIORCHARD_DATA_DIR=/data

# File storage backend for QA evidence uploads (and other user files).
# Default is local disk under ``FILE_STORAGE_LOCAL_DIR``. In Docker the
# local path resolves inside the container and is wiped on rebuild
# UNLESS the directory is volume-mounted (the default compose file
# mounts ``evidence_data:/app/data/uploads`` for you). For multi-host
# or production deploys, prefer S3.
# FILE_STORAGE_S3=false
# FILE_STORAGE_S3_BUCKET=
# AWS_REGION=us-east-1
# FILE_STORAGE_LOCAL_DIR=data/uploads
#
# AWS credentials are resolved through boto3's default chain, in order:
#   1. ``AWS_ACCESS_KEY_ID`` + ``AWS_SECRET_ACCESS_KEY`` env vars below.
#   2. ``~/.aws/credentials`` profile (default profile, or ``AWS_PROFILE``).
#   3. EC2 / ECS / EKS instance / task role.
# Set the env vars only when neither a profile file nor a role is
# available (CI, single-user dev box, sandboxed container). Prefer
# IAM roles in production — static keys in env are a credential-leak
# vector that rotates as often as the deploy.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=    # only if using temporary STS credentials

# Public URL (optional): set when using Cloudflare Tunnel or any reverse proxy
# PUBLIC_URL=https://api.bodhiorchard.yourdomain.com

# Cloudflare Tunnel (optional): only needed with docker compose --profile tunnel
# CLOUDFLARE_TUNNEL_TOKEN=
