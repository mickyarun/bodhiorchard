# Database
DATABASE_URL=postgresql+asyncpg://flowdev:flowdev@localhost:5432/flowdev

# Auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=llama3:8b
LLM_BASE_URL=http://localhost:11434
LLM_PREMIUM_PROVIDER=ollama
LLM_PREMIUM_MODEL=llama3:70b

# Embeddings
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Integrations
GITHUB_PAT=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Public URL (optional): set when using Cloudflare Tunnel or any reverse proxy
# PUBLIC_URL=https://api.flowdev.yourdomain.com

# Cloudflare Tunnel (optional): only needed with docker compose --profile tunnel
# CLOUDFLARE_TUNNEL_TOKEN=
