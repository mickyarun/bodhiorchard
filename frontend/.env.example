VITE_API_BASE_URL=http://localhost:8000/api

# When using Cloudflare Tunnel or any reverse proxy, set to the public API URL:
# VITE_API_BASE_URL=https://api.bodhiorchard.yourdomain.com/api

# Colyseus (multiplayer) endpoint override. Leave UNSET for local dev
# and reverse-proxied dev (ngrok, Tailscale Serve) — the frontend will
# route WebSocket traffic through the page origin at `/colyseus`, which
# Vite's dev proxy forwards to ws://localhost:2567. Set this only when
# Colyseus lives on its own hostname (prod) or you want to bypass the
# Vite proxy.
#
# Prod example:
#   VITE_COLYSEUS_URL=wss://mp.bodhiorchard.yourdomain.com
#
# Direct-to-server dev (bypasses Vite proxy):
#   VITE_COLYSEUS_URL=ws://localhost:2567
