    "@colyseus/ws-transport": "^0.17.13",
    "colyseus": "^0.17.10"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^1.6.1"
  }
}
